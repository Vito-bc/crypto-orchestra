# Copy this file to .env and fill in the values you need.
# NEVER commit .env to git — it is already in .gitignore.

# ── Anthropic Claude API (required) ──────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Coinbase Advanced Trade API (only needed for DRY_RUN=false) ──────────────
# Create a key at https://www.coinbase.com/settings/api with "Trade" permission.
COINBASE_API_KEY=
COINBASE_API_SECRET=

# ── Telegram alerts (optional but recommended) ────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Trading settings ──────────────────────────────────────────────────────────
TRADE_SIZE_PCT=0.02      # fraction of portfolio per trade (0.02 = 2%)
MAX_POSITIONS=5          # max concurrent open positions
DAILY_LOSS_LIMIT=0.05    # halt trading if daily loss exceeds 5%
DRY_RUN=true             # set to false ONLY when real API keys are configured

# ── Optional: override Claude model for sub-agents (default: haiku) ──────────
# SUBAGENT_MODEL=claude-haiku-4-5-20251001

# ── Optional: override scheduler interval ────────────────────────────────────
# PIPELINE_INTERVAL_MINUTES=60
